<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <tab id="run_as_root_typesense" translate="label" sortOrder="400">
            <label>TypeSense</label>
        </tab>
        <section id="run_as_root_typesense" translate="label" type="text"
                 sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
            <class>separator-top</class>
            <label>TypeSense Search</label>
            <tab>run_as_root_typesense</tab>
            <resource>RunAsRoot_TypeSense::configuration</resource>

            <!-- General Settings -->
            <group id="general" translate="label" type="text"
                   sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>General Settings</label>
                <field id="enabled" translate="label comment" type="select"
                       sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable TypeSense Search</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="protocol" translate="label comment" type="select"
                       sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Protocol</label>
                    <source_model>RunAsRoot\TypeSense\Model\Config\Source\Protocol</source_model>
                    <comment>Protocol for server-side indexing. Use 'http' for local/Docker setups, 'https' for production.</comment>
                </field>
                <field id="host" translate="label comment" type="text"
                       sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Host</label>
                    <comment>Internal hostname for indexing (e.g., 'typesense' in Docker, 'search.example.com' in production). Used by PHP for indexing, not by the browser.</comment>
                </field>
                <field id="port" translate="label comment" type="text"
                       sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Port</label>
                    <validate>validate-digits</validate>
                    <comment>Default Typesense port is 8108.</comment>
                </field>
                <field id="api_key" translate="label comment" type="obscure"
                       sortOrder="50" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Admin API Key</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <comment>Full-access key for indexing and collection management. Found in your Typesense server startup flags (--api-key). Never exposed to the frontend.</comment>
                </field>
                <field id="search_only_api_key" translate="label comment" type="text"
                       sortOrder="60" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Search-Only API Key</label>
                    <comment>Read-only key for browser search requests. Generate one via the Typesense API, or use the admin key for development (not recommended in production).</comment>
                </field>
                <field id="index_prefix" translate="label comment" type="text"
                       sortOrder="70" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Index Prefix</label>
                    <comment>Short prefix for all collection names (e.g., 'rar' creates 'rar_product_default'). Useful when multiple environments share one Typesense server. Changing this after indexing requires a full reindex.</comment>
                </field>
                <field id="search_protocol" translate="label comment" type="select"
                       sortOrder="80" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Frontend Search Protocol</label>
                    <source_model>RunAsRoot\TypeSense\Model\Config\Source\Protocol</source_model>
                    <comment>Frontend Search Node — Protocol for browser-side search requests. In Docker/Warden setups, this is usually 'https' via Traefik. Leave empty to use the server protocol above.</comment>
                </field>
                <field id="search_host" translate="label comment" type="text"
                       sortOrder="90" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Frontend Search Host</label>
                    <comment>Frontend Search Node — Public hostname the browser uses to reach Typesense (e.g., 'typesense.mystore.test'). In Docker/Warden, this differs from the server host. Leave empty to use the server host above.</comment>
                </field>
                <field id="search_port" translate="label comment" type="text"
                       sortOrder="100" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Frontend Search Port</label>
                    <validate>validate-digits</validate>
                    <comment>Frontend Search Node — Port for browser-side requests (e.g., 443 for HTTPS). Leave empty to use the server port above.</comment>
                </field>
                <field id="log_enabled" translate="label" type="select"
                       sortOrder="110" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Enable Logging</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
            </group>

            <!-- Indexing Settings -->
            <group id="indexing" translate="label" type="text"
                   sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Indexing</label>
                <field id="batch_size" translate="label comment" type="text"
                       sortOrder="10" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Batch Size</label>
                    <comment>Documents per import batch. Lower values use less memory but are slower. Default: 200. Increase to 500–1000 for large catalogs with sufficient memory.</comment>
                    <validate>validate-digits</validate>
                </field>
                <field id="product_enabled" translate="label" type="select"
                       sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable Product Indexing</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="category_enabled" translate="label" type="select"
                       sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable Category Indexing</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="cms_page_enabled" translate="label" type="select"
                       sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable CMS Page Indexing</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="suggestion_enabled" translate="label" type="select"
                       sortOrder="50" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable Suggestion Indexing</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="zero_downtime_enabled" translate="label comment" type="select"
                       sortOrder="60" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Zero-Downtime Reindexing</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>When enabled, indexing writes to a new collection, then swaps it live instantly. Your customers never see partial or empty results during reindex. Recommended for production.</comment>
                </field>
                <field id="cron_enabled" translate="label" type="select"
                       sortOrder="70" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Enable Cron Reindexing</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="cron_schedule" translate="label comment" type="text"
                       sortOrder="80" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Cron Schedule</label>
                    <comment>Standard cron expression. Examples: '0 2 * * *' (daily at 2 AM), '0 */6 * * *' (every 6 hours), '*/30 * * * *' (every 30 minutes).</comment>
                    <depends>
                        <field id="cron_enabled">1</field>
                    </depends>
                </field>
                <field id="queue_enabled" translate="label comment" type="select"
                       sortOrder="90" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Use Message Queue</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>When enabled, full reindex jobs are dispatched to the message queue (RabbitMQ or MySQL) and processed asynchronously in the background.</comment>
                </field>
            </group>

            <!-- Search Settings -->
            <group id="search" translate="label" type="text"
                   sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Search</label>
                <field id="typo_tolerance_enabled" translate="label" type="select"
                       sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable Typo Tolerance</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="typo_tolerance_min_word_length" translate="label comment" type="text"
                       sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Minimum Word Length for Typo Tolerance</label>
                    <validate>validate-digits</validate>
                </field>
                <field id="highlight_enabled" translate="label" type="select"
                       sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable Highlighting</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="query_suggestions_enabled" translate="label" type="select"
                       sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable Query Suggestions</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
            </group>

            <!-- Instant Search -->
            <group id="instant_search" translate="label" type="text"
                   sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Instant Search Result Page</label>
                <field id="enabled" translate="label" type="select"
                       sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable Instant Search</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="products_per_page" translate="label" type="text"
                       sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Products Per Page</label>
                    <validate>validate-digits</validate>
                </field>
                <field id="replace_category_page" translate="label comment" type="select"
                       sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Replace Category Pages</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Use TypeSense for category product listings.</comment>
                </field>
                <field id="image_type" translate="label" type="select"
                       sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Image Type</label>
                    <source_model>RunAsRoot\TypeSense\Model\Config\Source\ImageType</source_model>
                </field>
                <field id="image_width" translate="label" type="text"
                       sortOrder="50" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Image Width</label>
                    <validate>validate-digits</validate>
                </field>
                <field id="image_height" translate="label" type="text"
                       sortOrder="60" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Image Height</label>
                    <validate>validate-digits</validate>
                </field>
            </group>

            <!-- Autocomplete -->
            <group id="autocomplete" translate="label" type="text"
                   sortOrder="50" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Autocomplete</label>
                <field id="enabled" translate="label" type="select"
                       sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable Autocomplete</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="product_count" translate="label" type="text"
                       sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Product Suggestions Count</label>
                    <validate>validate-digits</validate>
                </field>
                <field id="category_count" translate="label" type="text"
                       sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Category Suggestions Count</label>
                    <validate>validate-digits</validate>
                </field>
                <field id="cms_page_count" translate="label" type="text"
                       sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>CMS Page Suggestions Count</label>
                    <validate>validate-digits</validate>
                </field>
                <field id="suggestion_count" translate="label" type="text"
                       sortOrder="50" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Query Suggestions Count</label>
                    <validate>validate-digits</validate>
                </field>
            </group>

            <!-- Merchandising -->
            <group id="merchandising" translate="label" type="text"
                   sortOrder="60" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Merchandising</label>
                <field id="category_merchandiser_enabled" translate="label" type="select"
                       sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable Category Merchandiser</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="query_merchandiser_enabled" translate="label" type="select"
                       sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable Query Merchandiser</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="landing_page_enabled" translate="label" type="select"
                       sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable Landing Pages</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
            </group>
        </section>
    </system>
</config>
