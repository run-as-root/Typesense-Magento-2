<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <!-- Interface preferences -->
    <preference for="RunAsRoot\TypeSense\Api\IndexerOrchestratorInterface"
                type="RunAsRoot\TypeSense\Model\Indexer\IndexerOrchestrator"/>

    <preference for="RunAsRoot\TypeSense\Api\TypeSenseClientFactoryInterface"
                type="RunAsRoot\TypeSense\Model\Client\TypeSenseClientFactory"/>

    <preference for="RunAsRoot\TypeSense\Model\Config\TypeSenseConfigInterface"
                type="RunAsRoot\TypeSense\Model\Config\TypeSenseConfig"/>

    <preference for="RunAsRoot\TypeSense\Api\CollectionManagerInterface"
                type="RunAsRoot\TypeSense\Model\Collection\CollectionManager"/>

    <preference for="RunAsRoot\TypeSense\Api\AliasManagerInterface"
                type="RunAsRoot\TypeSense\Model\Collection\AliasManager"/>

    <preference for="RunAsRoot\TypeSense\Api\CollectionNameResolverInterface"
                type="RunAsRoot\TypeSense\Model\Collection\CollectionNameResolver"/>

    <preference for="RunAsRoot\TypeSense\Model\Indexer\Product\AttributeResolverInterface"
                type="RunAsRoot\TypeSense\Model\Indexer\Product\AttributeResolver"/>

    <preference for="RunAsRoot\TypeSense\Model\Indexer\Product\PriceCalculatorInterface"
                type="RunAsRoot\TypeSense\Model\Indexer\Product\PriceCalculator"/>

    <preference for="RunAsRoot\TypeSense\Model\Indexer\Product\ImageResolverInterface"
                type="RunAsRoot\TypeSense\Model\Indexer\Product\ImageResolver"/>

    <preference for="RunAsRoot\TypeSense\Model\Indexer\Product\StockResolverInterface"
                type="RunAsRoot\TypeSense\Model\Indexer\Product\StockResolver"/>

    <preference for="RunAsRoot\TypeSense\Model\Indexer\Product\CategoryResolverInterface"
                type="RunAsRoot\TypeSense\Model\Indexer\Product\CategoryResolver"/>

    <preference for="RunAsRoot\TypeSense\Model\Indexer\Product\UrlResolverInterface"
                type="RunAsRoot\TypeSense\Model\Indexer\Product\UrlResolver"/>

    <preference for="RunAsRoot\TypeSense\Model\Indexer\Product\ProductSchemaProviderInterface"
                type="RunAsRoot\TypeSense\Model\Indexer\Product\ProductSchemaProvider"/>

    <preference for="RunAsRoot\TypeSense\Model\Indexer\Product\SalesCountResolverInterface"
                type="RunAsRoot\TypeSense\Model\Indexer\Product\SalesCountResolver"/>

    <preference for="RunAsRoot\TypeSense\Model\Indexer\Product\ReviewResolverInterface"
                type="RunAsRoot\TypeSense\Model\Indexer\Product\ReviewResolver"/>

    <preference for="RunAsRoot\TypeSense\Model\Indexer\Category\CategorySchemaProviderInterface"
                type="RunAsRoot\TypeSense\Model\Indexer\Category\CategorySchemaProvider"/>

    <preference for="RunAsRoot\TypeSense\Model\Indexer\CmsPage\CmsPageSchemaProviderInterface"
                type="RunAsRoot\TypeSense\Model\Indexer\CmsPage\CmsPageSchemaProvider"/>

    <preference for="RunAsRoot\TypeSense\Model\Indexer\Suggestion\SuggestionSchemaProviderInterface"
                type="RunAsRoot\TypeSense\Model\Indexer\Suggestion\SuggestionSchemaProvider"/>

    <preference for="RunAsRoot\TypeSense\Api\OrderSchemaProviderInterface"
                type="RunAsRoot\TypeSense\Model\Indexer\Order\OrderSchemaProvider"/>

    <preference for="RunAsRoot\TypeSense\Api\CustomerSchemaProviderInterface"
                type="RunAsRoot\TypeSense\Model\Indexer\Customer\CustomerSchemaProvider"/>

    <preference for="RunAsRoot\TypeSense\Api\StoreSchemaProviderInterface"
                type="RunAsRoot\TypeSense\Model\Indexer\Store\StoreSchemaProvider"/>

    <preference for="RunAsRoot\TypeSense\Api\SystemConfigSchemaProviderInterface"
                type="RunAsRoot\TypeSense\Model\Indexer\SystemConfig\SystemConfigSchemaProvider"/>

    <!-- Merchandising data interface preferences -->
    <preference for="RunAsRoot\TypeSense\Api\Data\CategoryMerchandisingInterface"
                type="RunAsRoot\TypeSense\Model\Merchandising\CategoryMerchandising"/>

    <preference for="RunAsRoot\TypeSense\Api\Data\QueryMerchandisingInterface"
                type="RunAsRoot\TypeSense\Model\Merchandising\QueryMerchandising"/>

    <!-- Curation service preferences -->
    <preference for="RunAsRoot\TypeSense\Api\OverrideManagerInterface"
                type="RunAsRoot\TypeSense\Model\Curation\OverrideManager"/>

    <!-- Merchandising repository preferences -->
    <preference for="RunAsRoot\TypeSense\Api\CategoryMerchandisingRepositoryInterface"
                type="RunAsRoot\TypeSense\Model\Merchandising\CategoryMerchandisingRepository"/>

    <preference for="RunAsRoot\TypeSense\Api\QueryMerchandisingRepositoryInterface"
                type="RunAsRoot\TypeSense\Model\Merchandising\QueryMerchandisingRepository"/>

    <!-- Entity indexer pool: register all entity indexers -->
    <type name="RunAsRoot\TypeSense\Model\Indexer\EntityIndexerPool">
        <arguments>
            <argument name="indexers" xsi:type="array">
                <item name="product" xsi:type="object">RunAsRoot\TypeSense\Model\Indexer\Product\ProductEntityIndexer</item>
                <item name="category" xsi:type="object">RunAsRoot\TypeSense\Model\Indexer\Category\CategoryEntityIndexer</item>
                <item name="cms_page" xsi:type="object">RunAsRoot\TypeSense\Model\Indexer\CmsPage\CmsPageEntityIndexer</item>
                <item name="suggestion" xsi:type="object">RunAsRoot\TypeSense\Model\Indexer\Suggestion\SuggestionEntityIndexer</item>
                <item name="order" xsi:type="object">RunAsRoot\TypeSense\Model\Indexer\Order\OrderEntityIndexer</item>
                <item name="customer" xsi:type="object">RunAsRoot\TypeSense\Model\Indexer\Customer\CustomerEntityIndexer</item>
                <item name="store" xsi:type="object">RunAsRoot\TypeSense\Model\Indexer\Store\StoreEntityIndexer</item>
                <item name="system_config" xsi:type="object">RunAsRoot\TypeSense\Model\Indexer\SystemConfig\SystemConfigEntityIndexer</item>
            </argument>
        </arguments>
    </type>

    <!-- Agent Assistant: Tool Registry with all registered tools -->
    <type name="RunAsRoot\TypeSense\Model\Assistant\ToolRegistry">
        <arguments>
            <argument name="tools" xsi:type="array">
                <item name="execute_sql" xsi:type="object">RunAsRoot\TypeSense\Model\Assistant\Tool\ExecuteSqlTool</item>
                <item name="describe_database" xsi:type="object">RunAsRoot\TypeSense\Model\Assistant\Tool\DescribeDatabaseTool</item>
                <item name="search_typesense" xsi:type="object">RunAsRoot\TypeSense\Model\Assistant\Tool\SearchTypesenseTool</item>
                <item name="compare_periods" xsi:type="object">RunAsRoot\TypeSense\Model\Assistant\Tool\ComparePeriodsTool</item>
                <item name="trend_analysis" xsi:type="object">RunAsRoot\TypeSense\Model\Assistant\Tool\TrendAnalysisTool</item>
                <item name="customer_segmentation" xsi:type="object">RunAsRoot\TypeSense\Model\Assistant\Tool\CustomerSegmentationTool</item>
                <item name="cohort_analysis" xsi:type="object">RunAsRoot\TypeSense\Model\Assistant\Tool\CohortAnalysisTool</item>
                <item name="frequently_bought_together" xsi:type="object">RunAsRoot\TypeSense\Model\Assistant\Tool\FrequentlyBoughtTogetherTool</item>
                <item name="inventory_forecast" xsi:type="object">RunAsRoot\TypeSense\Model\Assistant\Tool\InventoryForecastTool</item>
                <item name="detect_anomalies" xsi:type="object">RunAsRoot\TypeSense\Model\Assistant\Tool\DetectAnomaliesTool</item>
            </argument>
        </arguments>
    </type>

    <!-- CLI commands -->
    <type name="Magento\Framework\Console\CommandListInterface">
        <arguments>
            <argument name="commands" xsi:type="array">
                <item name="typesense_reindex" xsi:type="object">RunAsRoot\TypeSense\Console\Command\ReindexCommand</item>
                <item name="typesense_collection_list" xsi:type="object">RunAsRoot\TypeSense\Console\Command\CollectionListCommand</item>
                <item name="typesense_collection_delete" xsi:type="object">RunAsRoot\TypeSense\Console\Command\CollectionDeleteCommand</item>
                <item name="typesense_health" xsi:type="object">RunAsRoot\TypeSense\Console\Command\HealthCheckCommand</item>
            </argument>
        </arguments>
    </type>

</config>
