<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Indexer/etc/indexer.xsd">
    <indexer id="typesense_product"
             view_id="typesense_product"
             class="RunAsRoot\TypeSense\Model\Indexer\Product\ProductIndexer">
        <title translate="true">TypeSense Product Index</title>
        <description translate="true">Rebuilds TypeSense product search index</description>
    </indexer>
    <indexer id="typesense_category"
             view_id="typesense_category"
             class="RunAsRoot\TypeSense\Model\Indexer\Category\CategoryIndexer">
        <title translate="true">TypeSense Category Index</title>
        <description translate="true">Rebuilds TypeSense category search index</description>
    </indexer>
    <indexer id="typesense_cms_page"
             view_id="typesense_cms_page"
             class="RunAsRoot\TypeSense\Model\Indexer\CmsPage\CmsPageIndexer">
        <title translate="true">TypeSense CMS Page Index</title>
        <description translate="true">Rebuilds TypeSense CMS page search index</description>
    </indexer>
    <indexer id="typesense_suggestion"
             view_id="typesense_suggestion"
             class="RunAsRoot\TypeSense\Model\Indexer\Suggestion\SuggestionIndexer">
        <title translate="true">TypeSense Suggestion Index</title>
        <description translate="true">Rebuilds TypeSense search suggestion index</description>
    </indexer>
</config>
