<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">

    <!-- Category Merchandising -->
    <table name="run_as_root_typesense_category_merchandising" resource="default" engine="innodb"
           comment="TypeSense Category Merchandising Rules">
        <column xsi:type="int" name="id" unsigned="true" nullable="false" identity="true" comment="ID"/>
        <column xsi:type="int" name="category_id" unsigned="true" nullable="false" comment="Category ID"/>
        <column xsi:type="smallint" name="store_id" unsigned="true" nullable="false" comment="Store ID"/>
        <column xsi:type="int" name="product_id" unsigned="true" nullable="false" comment="Product ID"/>
        <column xsi:type="int" name="position" unsigned="false" nullable="false" default="0" comment="Position"/>
        <column xsi:type="varchar" name="action" nullable="false" length="10" comment="Action (pin or hide)"/>
        <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP" comment="Created At"/>
        <column xsi:type="timestamp" name="updated_at" nullable="false" default="CURRENT_TIMESTAMP" on_update="true" comment="Updated At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="id"/>
        </constraint>
        <constraint xsi:type="unique" referenceId="UNQ_TS_CAT_MERCH_CAT_STORE_PROD">
            <column name="category_id"/>
            <column name="store_id"/>
            <column name="product_id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="FK_TS_CAT_MERCH_STORE"
                    table="run_as_root_typesense_category_merchandising" column="store_id"
                    referenceTable="store" referenceColumn="store_id" onDelete="CASCADE"/>
    </table>

    <!-- Query Merchandising -->
    <table name="run_as_root_typesense_query_merchandising" resource="default" engine="innodb"
           comment="TypeSense Query Merchandising Rules">
        <column xsi:type="int" name="id" unsigned="true" nullable="false" identity="true" comment="ID"/>
        <column xsi:type="varchar" name="query" nullable="false" length="255" comment="Search Query"/>
        <column xsi:type="varchar" name="match_type" nullable="false" length="10" default="exact" comment="Match Type"/>
        <column xsi:type="smallint" name="store_id" unsigned="true" nullable="false" comment="Store ID"/>
        <column xsi:type="json" name="includes" nullable="true" comment="Included Products JSON"/>
        <column xsi:type="json" name="excludes" nullable="true" comment="Excluded Products JSON"/>
        <column xsi:type="json" name="banner_config" nullable="true" comment="Banner Configuration JSON"/>
        <column xsi:type="boolean" name="is_active" nullable="false" default="true" comment="Is Active"/>
        <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP" comment="Created At"/>
        <column xsi:type="timestamp" name="updated_at" nullable="false" default="CURRENT_TIMESTAMP" on_update="true" comment="Updated At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="id"/>
        </constraint>
        <constraint xsi:type="unique" referenceId="UNQ_TS_QUERY_MERCH_QUERY_STORE">
            <column name="query"/>
            <column name="store_id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="FK_TS_QUERY_MERCH_STORE"
                    table="run_as_root_typesense_query_merchandising" column="store_id"
                    referenceTable="store" referenceColumn="store_id" onDelete="CASCADE"/>
    </table>

    <!-- Landing Pages -->
    <table name="run_as_root_typesense_landing_page" resource="default" engine="innodb"
           comment="TypeSense Landing Pages">
        <column xsi:type="int" name="id" unsigned="true" nullable="false" identity="true" comment="ID"/>
        <column xsi:type="varchar" name="url_key" nullable="false" length="255" comment="URL Key"/>
        <column xsi:type="smallint" name="store_id" unsigned="true" nullable="false" comment="Store ID"/>
        <column xsi:type="varchar" name="title" nullable="false" length="255" comment="Page Title"/>
        <column xsi:type="text" name="meta_description" nullable="true" comment="Meta Description"/>
        <column xsi:type="varchar" name="query" nullable="false" length="255" default="*" comment="Base Search Query"/>
        <column xsi:type="text" name="filter_by" nullable="true" comment="Filter By Clause"/>
        <column xsi:type="varchar" name="sort_by" nullable="true" length="255" comment="Sort By"/>
        <column xsi:type="json" name="includes" nullable="true" comment="Included Products JSON"/>
        <column xsi:type="json" name="excludes" nullable="true" comment="Excluded Products JSON"/>
        <column xsi:type="json" name="banner_config" nullable="true" comment="Banner Configuration JSON"/>
        <column xsi:type="text" name="cms_content" nullable="true" comment="CMS Content"/>
        <column xsi:type="boolean" name="is_active" nullable="false" default="true" comment="Is Active"/>
        <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP" comment="Created At"/>
        <column xsi:type="timestamp" name="updated_at" nullable="false" default="CURRENT_TIMESTAMP" on_update="true" comment="Updated At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="id"/>
        </constraint>
        <constraint xsi:type="unique" referenceId="UNQ_TS_LANDING_URL_STORE">
            <column name="url_key"/>
            <column name="store_id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="FK_TS_LANDING_STORE"
                    table="run_as_root_typesense_landing_page" column="store_id"
                    referenceTable="store" referenceColumn="store_id" onDelete="CASCADE"/>
    </table>
</schema>
