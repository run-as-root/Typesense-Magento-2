<?xml version="1.0"?>
<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">typesense_landing_page_form.typesense_landing_page_form_data_source</item>
        </item>
        <item name="label" xsi:type="string" translate="true">Landing Page</item>
        <item name="template" xsi:type="string">templates/form/collapsible</item>
    </argument>
    <settings>
        <buttons>
            <button name="back">
                <url path="*/*/index"/>
                <class>back</class>
                <label translate="true">Back</label>
            </button>
            <button name="delete">
                <class>delete</class>
                <label translate="true">Delete</label>
                <aclResource>RunAsRoot_TypeSense::landing_pages</aclResource>
                <url path="*/*/delete">
                    <param name="id">${ $.$data.id }</param>
                </url>
            </button>
            <button name="save">
                <class>save primary</class>
                <label translate="true">Save</label>
            </button>
        </buttons>
        <namespace>typesense_landing_page_form</namespace>
        <dataScope>data</dataScope>
        <deps>
            <dep>typesense_landing_page_form.typesense_landing_page_form_data_source</dep>
        </deps>
    </settings>
    <dataSource name="typesense_landing_page_form_data_source">
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array">
                <item name="component" xsi:type="string">Magento_Ui/js/form/provider</item>
            </item>
        </argument>
        <settings>
            <submitUrl path="typesense/landingpage/save"/>
        </settings>
        <aclResource>RunAsRoot_TypeSense::landing_pages</aclResource>
        <dataProvider class="RunAsRoot\TypeSense\Ui\Component\Form\DataProvider\LandingPageFormDataProvider"
                      name="typesense_landing_page_form_data_source">
            <settings>
                <requestFieldName>id</requestFieldName>
                <primaryFieldName>id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <fieldset name="general">
        <settings>
            <collapsible>false</collapsible>
            <label translate="true">General</label>
        </settings>
        <field name="id" formElement="input">
            <settings>
                <dataType>text</dataType>
                <visible>false</visible>
            </settings>
        </field>
        <field name="url_key" formElement="input">
            <settings>
                <dataType>text</dataType>
                <label translate="true">URL Key</label>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
                <notice translate="true">URL path for this page (e.g., 'summer-sale' becomes yourstore.com/summer-sale). Use lowercase letters, numbers, and hyphens only.</notice>
            </settings>
        </field>
        <field name="title" formElement="input">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Title</label>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
            </settings>
        </field>
        <field name="store_id" formElement="select">
            <settings>
                <dataType>int</dataType>
                <label translate="true">Store</label>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options class="Magento\Store\Model\System\Store"/>
                    </settings>
                </select>
            </formElements>
        </field>
        <field name="is_active" formElement="checkbox">
            <settings>
                <dataType>boolean</dataType>
                <label translate="true">Is Active</label>
            </settings>
            <formElements>
                <checkbox>
                    <settings>
                        <valueMap>
                            <map name="false" xsi:type="string">0</map>
                            <map name="true" xsi:type="string">1</map>
                        </valueMap>
                        <prefer>toggle</prefer>
                    </settings>
                </checkbox>
            </formElements>
        </field>
    </fieldset>
    <fieldset name="search_configuration">
        <settings>
            <collapsible>true</collapsible>
            <opened>true</opened>
            <label translate="true">Search Configuration</label>
        </settings>
        <field name="query" formElement="input">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Query</label>
                <notice translate="true">The search query to match. Use * for all products.</notice>
            </settings>
        </field>
        <field name="filter_by" formElement="textarea">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Filter By</label>
                <notice translate="true">Typesense filter syntax. Examples: brand:=Nike, price:&gt;50, in_stock:true. Combine with: brand:=Nike &amp;&amp; price:&gt;50</notice>
            </settings>
        </field>
        <field name="sort_by" formElement="input">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Sort By</label>
                <notice translate="true">Field and direction. Examples: price:asc, created_at:desc, _text_match:desc (relevance)</notice>
            </settings>
        </field>
    </fieldset>
    <fieldset name="seo">
        <settings>
            <collapsible>true</collapsible>
            <opened>false</opened>
            <label translate="true">SEO</label>
        </settings>
        <field name="meta_description" formElement="textarea">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Meta Description</label>
            </settings>
        </field>
    </fieldset>
    <fieldset name="content">
        <settings>
            <collapsible>true</collapsible>
            <opened>false</opened>
            <label translate="true">Content</label>
        </settings>
        <field name="cms_content" formElement="wysiwyg">
            <settings>
                <dataType>text</dataType>
                <label translate="true">CMS Content</label>
            </settings>
            <formElements>
                <wysiwyg>
                    <settings>
                        <rows>20</rows>
                        <wysiwyg>true</wysiwyg>
                    </settings>
                </wysiwyg>
            </formElements>
        </field>
    </fieldset>
    <fieldset name="banner">
        <settings>
            <collapsible>true</collapsible>
            <opened>false</opened>
            <label translate="true">Banner</label>
        </settings>
        <field name="banner_config" formElement="textarea">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Banner Config (JSON)</label>
                <notice translate="true">JSON configuration for the banner displayed on this landing page.</notice>
            </settings>
        </field>
    </fieldset>
    <fieldset name="product_merchandising">
        <settings>
            <collapsible>true</collapsible>
            <opened>true</opened>
            <label translate="true">Product Merchandising</label>
        </settings>
        <field name="includes" formElement="input">
            <settings>
                <dataType>text</dataType>
                <visible>false</visible>
                <label translate="true">Includes (JSON)</label>
            </settings>
        </field>
        <field name="excludes" formElement="input">
            <settings>
                <dataType>text</dataType>
                <visible>false</visible>
                <label translate="true">Excludes (JSON)</label>
            </settings>
        </field>
        <htmlContent name="landing_page_merchandiser_widget">
            <argument name="block" xsi:type="object">Magento\Framework\View\Element\Template</argument>
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="component" xsi:type="string">Magento_Ui/js/form/components/html</item>
                </item>
            </argument>
            <settings>
                <additionalClasses>
                    <class name="typesense-landing-page-merchandiser-container">true</class>
                </additionalClasses>
            </settings>
        </htmlContent>
    </fieldset>
</form>
