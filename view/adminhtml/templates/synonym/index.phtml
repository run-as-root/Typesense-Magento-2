<?php
/** @var \Magento\Framework\View\Element\Template $block */
/** @var \RunAsRoot\TypeSense\ViewModel\Adminhtml\SynonymViewModel $viewModel */

declare(strict_types=1);

$viewModel   = $block->getData('view_model');
$collection  = (string) $block->getRequest()->getParam('collection', '');
$collections = $viewModel->getCollections();
$synonyms    = $collection !== '' ? $viewModel->getSynonyms($collection) : [];
?>

<style>
    .ts-synonyms { max-width: 1000px; }

    .ts-card {
        background: #fff; border: 1px solid #e0e0e0; border-radius: 8px; overflow: hidden; margin-bottom: 20px;
    }
    .ts-card-header {
        padding: 14px 20px; font-size: 13px; font-weight: 700; text-transform: uppercase;
