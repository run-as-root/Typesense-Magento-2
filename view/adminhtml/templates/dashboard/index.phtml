<?php
/** @var \Magento\Framework\View\Element\Template $block */
/** @var \RunAsRoot\TypeSense\ViewModel\Adminhtml\DashboardViewModel $viewModel */

declare(strict_types=1);

$viewModel      = $block->getData('view_model');
$isConnected    = $viewModel->isConnected();
$connectionInfo = $viewModel->getConnectionInfo();
$collections    = $viewModel->getCollections();
$aliasesResult  = $viewModel->getAliases();

$aliasMap = [];
foreach ($aliasesResult['aliases'] ?? [] as $alias) {
    $collectionName = $alias['collection_name'] ?? '';
    $aliasName      = $alias['name'] ?? '';
    if ($collectionName !== '' && $aliasName !== '') {
        $aliasMap[$collectionName] = $aliasName;
    }
}

$configUrl = $block->getUrl('adminhtml/system_config/edit', ['section' => 'run_as_root_typesense']);

$checks = [
    ['pass' => $viewModel->isEnabled(), 'label' => __('Module enabled')],
    ['pass' => $viewModel->hasApiKey(), 'label' => __('Admin API key configured')],
    ['pass' => $viewModel->hasSearchOnlyApiKey(), 'label' => __('Search-only API key configured')],
    ['pass' => $isConnected, 'label' => __('Typesense connection healthy')],
    ['pass' => $viewModel->getTotalDocuments() > 0, 'label' => __('Products indexed')],
    ['pass' => $viewModel->isAutocompleteEnabled(), 'label' => __('Autocomplete enabled')],
];
$allPass = array_reduce($checks, fn(bool $carry, array $c) => $carry && $c['pass'], true);
$passCount = count(array_filter($checks, fn(array $c) => $c['pass']));
$totalDocs = $viewModel->getTotalDocuments();
?>

