                    <div class="admin__field">
                        <div class="admin__field-label">
                            <span><?= $block->escapeHtml(__('Protocol')) ?></span>
                        </div>
                        <div class="admin__field-control">
                            <span><?= $block->escapeHtml((string) $connectionInfo['protocol']) ?></span>
                        </div>
                    </div>

                    <?php if (!$isConnected): ?>
                        <div class="admin__field">
                            <div class="admin__field-control">
                                <div class="message message-warning">
                                    <strong><?= $block->escapeHtml(__('Troubleshooting hints:')) ?></strong>
                                    <ul style="margin:0.5rem 0 0 1.25rem; padding:0;">
                                        <li><?= $block->escapeHtml(__('Check your Typesense host and port in Configuration')) ?></li>
