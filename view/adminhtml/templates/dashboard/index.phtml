    <!-- Collections Table -->
    <div class="admin__page-section-content">
        <div class="admin__fieldset">
            <div class="admin__fieldset-wrapper">
                <div class="admin__fieldset-wrapper-title">
                    <span>
                        <?= $block->escapeHtml(__('Collections (%1)', count($collections))) ?>
                    </span>
                </div>
                <div class="admin__fieldset-wrapper-content">
                    <?php if (empty($collections)): ?>
                        <p class="message message-notice">
                            <?= $block->escapeHtml(__('No collections found. Check your connection settings or run a reindex.')) ?>
                        </p>
                    <?php else: ?>
                        <table class="data-grid">
                            <thead>
                                <tr>
                                    <th class="data-grid-th"><?= $block->escapeHtml(__('Name')) ?></th>
                                    <th class="data-grid-th"><?= $block->escapeHtml(__('Document Count')) ?></th>
                                    <th class="data-grid-th"><?= $block->escapeHtml(__('Created At')) ?></th>
                                    <th class="data-grid-th"
                                        title="<?= $block->escapeHtmlAttr(__('An alias points to the active collection. During zero-downtime reindex, the alias switches to the new collection automatically.')) ?>">
                                        <?= $block->escapeHtml(__('Alias')) ?>
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                <?php foreach ($collections as $collection): ?>
                                    <?php
                                    $name         = (string) ($collection['name'] ?? '');
                                    $numDocuments = (int) ($collection['num_documents'] ?? 0);
                                    $createdAt    = isset($collection['created_at'])
                                        ? date('Y-m-d H:i:s', (int) $collection['created_at'])
                                        : '';
                                    $alias        = $aliasMap[$name] ?? '';
                                    $rowStyle     = $numDocuments === 0 ? ' style="background:#fff8e1;"' : '';
                                    ?>
                                    <tr<?= $rowStyle ?>>
                                        <td><?= $block->escapeHtml($name) ?></td>
                                        <td><?= $block->escapeHtml((string) $numDocuments) ?></td>
                                        <td><?= $block->escapeHtml($createdAt) ?></td>
                                        <td>
                                            <?php if ($alias !== ''): ?>
                                                <?= $block->escapeHtml($alias) ?>
                                                <span style="color:#185b00; font-weight:bold;"><?= $block->escapeHtml(__(' (live)')) ?></span>
                                            <?php endif; ?>
                                        </td>
                                    </tr>
                                <?php endforeach; ?>
                            </tbody>
                        </table>
                    <?php endif; ?>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
require(['jquery'], function ($) {
    'use strict';

    $('#typesense-test-connection').on('click', function () {
        var $btn    = $(this);
        var $result = $('#typesense-test-connection-result');

        $btn.prop('disabled', true);
        $result.css('color', '').text('<?= $block->escapeJs(__('Testing...')) ?>');

        $.ajax({
            url:      '<?= $block->escapeJs($block->getUrl('typesense/dashboard/testconnection')) ?>',
            method:   'GET',
            dataType: 'json',
            success: function (data) {
                if (data && data.success) {
                    $result.css('color', '#185b00').text('<?= $block->escapeJs(__('Connected successfully!')) ?>');
                } else {
                    var msg = (data && data.message) ? data.message : '<?= $block->escapeJs(__('Connection failed')) ?>';
                    $result.css('color', '#b40000').text(msg);
                }
            },
            error: function () {
                $result.css('color', '#b40000').text('<?= $block->escapeJs(__('Request failed. Check browser console.')) ?>');
            },
            complete: function () {
                $btn.prop('disabled', false);
            }
        });
    });
});
</script>
