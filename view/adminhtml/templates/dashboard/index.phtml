                                        <li><?= $block->escapeHtml(__("If using Docker/Warden, the host should be the container name (e.g., 'typesense'), not 'localhost'")) ?></li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    <?php endif; ?>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="admin__page-section-content">
        <div class="admin__fieldset">
            <div class="admin__fieldset-wrapper">
                <div class="admin__fieldset-wrapper-title">
                    <span><?= $block->escapeHtml(__('Quick Actions')) ?></span>
                </div>
                <div class="admin__fieldset-wrapper-content">
                    <div class="admin__field">
                        <div class="admin__field-control">
                            <button type="button"
                                    class="action-default scalable"
                                    title="<?= $block->escapeHtmlAttr(__('Reindex via CLI: bin/magento typesense:reindex')) ?>">
                                <span><?= $block->escapeHtml(__('Reindex All (CLI)')) ?></span>
