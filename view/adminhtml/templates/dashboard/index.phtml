<script>
require(['jquery'], function ($) {
    'use strict';
    $('#typesense-test-connection').on('click', function () {
        var $btn = $(this), $result = $('#typesense-test-connection-result');
        $btn.prop('disabled', true);
        $result.css('color', '#888').text('Testing...');
        $.ajax({
            url: '<?= $block->escapeJs($block->getUrl('typesense/dashboard/testconnection')) ?>',
            method: 'GET',
            dataType: 'json',
            success: function (data) {
                if (data && data.success) {
                    $result.css('color', '#2e7d32').text('✓ ' + (data.message || 'Connected'));
                } else {
                    $result.css('color', '#c62828').text('✗ ' + (data.message || 'Failed'));
                }
            },
            error: function () {
                $result.css('color', '#c62828').text('✗ Request failed');
            },
            complete: function () { $btn.prop('disabled', false); }
        });
    });
});
</script>
