<?php
/** @var \Magento\Framework\View\Element\Template $block */
/** @var \RunAsRoot\TypeSense\ViewModel\Adminhtml\DashboardViewModel $viewModel */

declare(strict_types=1);

$viewModel      = $block->getData('view_model');
$isConnected    = $viewModel->isConnected();
$connectionInfo = $viewModel->getConnectionInfo();
$collections    = $viewModel->getCollections();
$aliasesResult  = $viewModel->getAliases();

// Build a map from collection name => alias name for quick lookup
$aliasMap = [];
foreach ($aliasesResult['aliases'] ?? [] as $alias) {
    $collectionName = $alias['collection_name'] ?? '';
    $aliasName      = $alias['name'] ?? '';
    if ($collectionName !== '' && $aliasName !== '') {
        $aliasMap[$collectionName] = $aliasName;
    }
}

$configUrl = $block->getUrl('adminhtml/system_config/edit', ['section' => 'run_as_root_typesense']);

// Checklist checks
$checks = [
    [
        'pass'  => $viewModel->isEnabled(),
        'label' => __('Module enabled'),
        'fix'   => sprintf('<a href="%s">%s</a>', $block->escapeUrl($configUrl), $block->escapeHtml(__('Go to Configuration'))),
    ],
    [
        'pass'  => $viewModel->hasApiKey(),
        'label' => __('Admin API key set'),
        'fix'   => sprintf('<a href="%s">%s</a>', $block->escapeUrl($configUrl), $block->escapeHtml(__('Go to Configuration'))),
    ],
    [
        'pass'  => $viewModel->hasSearchOnlyApiKey(),
        'label' => __('Search-only API key set'),
        'fix'   => sprintf('<a href="%s">%s</a>', $block->escapeUrl($configUrl), $block->escapeHtml(__('Go to Configuration'))),
    ],
    [
        'pass'  => $isConnected,
        'label' => __('Connection healthy'),
        'fix'   => $block->escapeHtml(__('Check host/port settings')),
    ],
    [
        'pass'  => $viewModel->getTotalDocuments() > 0,
        'label' => __('Products indexed'),
        'fix'   => '<code>' . $block->escapeHtml(__('Run: bin/magento typesense:reindex')) . '</code>',
    ],
    [
        'pass'  => $viewModel->isAutocompleteEnabled(),
        'label' => __('Autocomplete enabled'),
        'fix'   => sprintf('<a href="%s">%s</a>', $block->escapeUrl($configUrl), $block->escapeHtml(__('Go to Configuration'))),
    ],
];

$allPass = array_reduce($checks, fn(bool $carry, array $check) => $carry && $check['pass'], true);
?>
<div class="admin__page-section">
    <div class="admin__page-section-title">
        <span class="title"><?= $block->escapeHtml(__('TypeSense Dashboard')) ?></span>
    </div>

    <!-- Smart Checklist -->
    <div class="admin__page-section-content">
        <?php if ($allPass): ?>
            <div class="message message-success">
                <strong>&#10003; <?= $block->escapeHtml(__('All systems operational')) ?></strong>
            </div>
        <?php else: ?>
            <div class="message message-error">
                <strong><?= $block->escapeHtml(__('Setup checklist — fix the items below:')) ?></strong>
                <ul style="margin:0.75rem 0 0 1.25rem; padding:0;">
                    <?php foreach ($checks as $check): ?>
                        <li style="margin-bottom:0.35rem;">
                            <?php if ($check['pass']): ?>
                                <span style="color:#185b00; font-weight:bold;">&#10003;</span>
                                <?= $block->escapeHtml((string) $check['label']) ?>
                            <?php else: ?>
                                <span style="color:#b40000; font-weight:bold;">&#10007;</span>
                                <?= $block->escapeHtml((string) $check['label']) ?>
                                &mdash; <?= $check['fix'] /* already escaped/safe */ ?>
                            <?php endif; ?>
                        </li>
                    <?php endforeach; ?>
                </ul>
            </div>
        <?php endif; ?>
    </div>

    <!-- Connection Status -->
    <div class="admin__page-section-content">
        <div class="admin__fieldset">
            <div class="admin__fieldset-wrapper">
                <div class="admin__fieldset-wrapper-title">
                    <span><?= $block->escapeHtml(__('Connection Status')) ?></span>
                </div>
