<?php
/** @var \Magento\Framework\View\Element\Template $block */
/** @var \RunAsRoot\TypeSense\ViewModel\Adminhtml\CollectionViewModel $viewModel */

declare(strict_types=1);

$viewModel  = $block->getData('view_model');
$name       = (string) $block->getRequest()->getParam('name', '');
$collection = $viewModel->getCollectionDetails($name);
$documents  = $viewModel->getDocuments($name, 10);
$fields     = $collection['fields'] ?? [];
$hits       = $documents['hits'] ?? [];
$found      = (int) ($documents['found'] ?? 0);
$numDocs    = (int) ($collection['num_documents'] ?? 0);

$previewFields = ['id', 'product_id', 'name', 'sku', 'price', 'in_stock', 'type_id', 'categories.lvl0', 'q', 'title', 'url', 'url_key'];
?>

<style>
    .ts-view { max-width: 1200px; }

    .ts-view-header {
        display: flex; align-items: center; gap: 16px; margin-bottom: 24px;
    }
    .ts-view-title { font-size: 18px; font-weight: 700; color: #333; font-family: monospace; }
    .ts-view-meta {
        display: flex; gap: 16px; margin-left: auto;
    }
    .ts-view-stat {
        text-align: center; padding: 8px 20px; background: #fafafa; border: 1px solid #e8e8e8; border-radius: 6px;
    }
    .ts-view-stat-value { font-size: 20px; font-weight: 700; color: #333; }
    .ts-view-stat-label { font-size: 10px; text-transform: uppercase; letter-spacing: 0.5px; color: #999; }

    .ts-card {
        background: #fff; border: 1px solid #e0e0e0; border-radius: 8px; overflow: hidden; margin-bottom: 24px;
    }
    .ts-card-header {
        padding: 14px 20px; font-size: 13px; font-weight: 700; text-transform: uppercase;
        letter-spacing: 0.5px; color: #555; background: #fafafa; border-bottom: 1px solid #e8e8e8;
        display: flex; align-items: center; gap: 8px;
    }
    .ts-card-header .ts-count { font-weight: 400; color: #aaa; }

    /* Schema table */
    .ts-schema { width: 100%; border-collapse: collapse; }
    .ts-schema th {
        text-align: left; padding: 10px 20px; font-size: 10px; font-weight: 700;
        text-transform: uppercase; letter-spacing: 0.5px; color: #999;
        border-bottom: 1px solid #f0f0f0;
    }
    .ts-schema td { padding: 10px 20px; border-bottom: 1px solid #f5f5f5; font-size: 13px; }
    .ts-schema tr:hover td { background: #fafafa; }
    .ts-schema .ts-fname { font-family: monospace; font-size: 13px; color: #333; font-weight: 500; }

    .ts-type-badge {
        display: inline-block; padding: 2px 8px; border-radius: 4px;
        font-size: 11px; font-weight: 600; font-family: monospace;
        background: #e3f2fd; color: #1565c0;
    }
    .ts-bool-badge {
        display: inline-block; width: 20px; height: 20px; border-radius: 50%;
        font-size: 10px; font-weight: 700; color: #fff;
        text-align: center; line-height: 20px;
    }
    .ts-bool-yes { background: #4caf50; }
    .ts-bool-no { background: #e0e0e0; color: #999; }

    /* Document cards */
    .ts-doc {
        border-bottom: 1px solid #f0f0f0; padding: 16px 20px;
    }
    .ts-doc:last-child { border-bottom: none; }
    .ts-doc:hover { background: #fafafa; }

    .ts-doc-title {
        font-size: 14px; font-weight: 600; color: #333; margin-bottom: 10px;
        display: flex; align-items: center; gap: 8px;
    }
    .ts-doc-id { font-size: 11px; color: #999; font-weight: 400; }

    .ts-doc-fields {
        display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 6px 16px;
    }
    .ts-doc-field { font-size: 12px; }
    .ts-doc-label { color: #aaa; font-size: 10px; text-transform: uppercase; letter-spacing: 0.3px; }
    .ts-doc-val { color: #333; font-weight: 500; word-break: break-word; }

    .ts-doc-toggle {
        margin-top: 10px; font-size: 11px; color: #1979c3; cursor: pointer;
        border: none; background: none; padding: 0;
    }
    .ts-doc-toggle:hover { text-decoration: underline; }
    .ts-doc-raw {
        display: none; margin-top: 10px; padding: 12px; background: #f8f9fa;
        border: 1px solid #e8e8e8; border-radius: 4px; font-family: monospace;
        font-size: 11px; white-space: pre-wrap; word-break: break-all;
        max-height: 250px; overflow-y: auto; color: #555;
    }

    .ts-back-link {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 8px 16px; border-radius: 4px; font-size: 13px; font-weight: 500;
        text-decoration: none; border: 1px solid #ddd; background: #fff; color: #333;
    }
    .ts-back-link:hover { background: #f5f5f5; border-color: #ccc; }
</style>

<div class="ts-view">

    <!-- Header -->
    <div class="ts-view-header">
        <a href="<?= $block->escapeUrl($block->getUrl('*/*/index')) ?>" class="ts-back-link">
            ← <?= $block->escapeHtml(__('Collections')) ?>
        </a>
        <span class="ts-view-title"><?= $block->escapeHtml($name) ?></span>
        <div class="ts-view-meta">
            <div class="ts-view-stat">
                <div class="ts-view-stat-value"><?= $block->escapeHtml(number_format($numDocs)) ?></div>
                <div class="ts-view-stat-label"><?= $block->escapeHtml(__('Documents')) ?></div>
            </div>
            <div class="ts-view-stat">
                <div class="ts-view-stat-value"><?= count($fields) ?></div>
                <div class="ts-view-stat-label"><?= $block->escapeHtml(__('Fields')) ?></div>
            </div>
        </div>
    </div>

    <!-- Schema Fields -->
    <div class="ts-card">
        <div class="ts-card-header">
            <?= $block->escapeHtml(__('Schema')) ?>
            <span class="ts-count">(<?= count($fields) ?> <?= $block->escapeHtml(__('fields')) ?>)</span>
        </div>
        <?php if (empty($fields)): ?>
            <div style="padding:20px; color:#999; font-size:13px;">
                <?= $block->escapeHtml(__('No schema fields found.')) ?>
            </div>
        <?php else: ?>
            <table class="ts-schema">
                <thead>
                    <tr>
                        <th style="width:35%;"><?= $block->escapeHtml(__('Field')) ?></th>
                        <th style="width:15%;"><?= $block->escapeHtml(__('Type')) ?></th>
                        <th style="width:10%; text-align:center;"
                            title="<?= $block->escapeHtmlAttr(__('Faceted fields can be used for filtering and aggregation.')) ?>">
                            <?= $block->escapeHtml(__('Facet')) ?>
                        </th>
                        <th style="width:10%; text-align:center;"
                            title="<?= $block->escapeHtmlAttr(__('Optional fields may be missing from some documents.')) ?>">
                            <?= $block->escapeHtml(__('Optional')) ?>
                        </th>
                        <th style="width:10%; text-align:center;"
                            title="<?= $block->escapeHtmlAttr(__('Indexed fields are searchable. Non-indexed fields are stored only.')) ?>">
                            <?= $block->escapeHtml(__('Indexed')) ?>
                        </th>
                    </tr>
                </thead>
                <tbody>
                    <?php foreach ($fields as $field): ?>
                        <?php
                        $isFacet = (bool) ($field['facet'] ?? false);
                        $isOptional = (bool) ($field['optional'] ?? false);
                        $isIndex = ($field['index'] ?? true) !== false;
                        ?>
                        <tr>
                            <td class="ts-fname"><?= $block->escapeHtml((string) ($field['name'] ?? '')) ?></td>
                            <td><span class="ts-type-badge"><?= $block->escapeHtml((string) ($field['type'] ?? '')) ?></span></td>
                            <td style="text-align:center;">
                                <span class="ts-bool-badge <?= $isFacet ? 'ts-bool-yes' : 'ts-bool-no' ?>"><?= $isFacet ? '✓' : '–' ?></span>
                            </td>
                            <td style="text-align:center;">
                                <span class="ts-bool-badge <?= $isOptional ? 'ts-bool-yes' : 'ts-bool-no' ?>"><?= $isOptional ? '✓' : '–' ?></span>
                            </td>
                            <td style="text-align:center;">
                                <span class="ts-bool-badge <?= $isIndex ? 'ts-bool-yes' : 'ts-bool-no' ?>"><?= $isIndex ? '✓' : '–' ?></span>
                            </td>
                        </tr>
                    <?php endforeach; ?>
                </tbody>
            </table>
        <?php endif; ?>
    </div>

    <!-- Documents -->
    <div class="ts-card">
        <div class="ts-card-header">
            <?= $block->escapeHtml(__('Documents')) ?>
            <span class="ts-count">(<?= $block->escapeHtml(__('showing 10 of %1', number_format($found))) ?>)</span>
        </div>
        <?php if (empty($hits)): ?>
            <div style="padding:20px; color:#999; font-size:13px;">
                <?= $block->escapeHtml(__('No documents found in this collection.')) ?>
            </div>
        <?php else: ?>
            <?php foreach ($hits as $index => $hit): ?>
                <?php
                $doc = $hit['document'] ?? [];
                $docName = (string) ($doc['name'] ?? $doc['q'] ?? $doc['title'] ?? '');
                $docId = (string) ($doc['id'] ?? '');
                $docSku = (string) ($doc['sku'] ?? '');
                $imgUrl = (string) ($doc['image_url'] ?? '');
                ?>
                <div class="ts-doc">
                    <div class="ts-doc-title">
                        <?php if ($imgUrl !== ''): ?>
                            <img src="<?= $block->escapeUrl($imgUrl) ?>"
                                 alt="" style="width:32px; height:32px; object-fit:contain; border-radius:4px; border:1px solid #eee;"/>
                        <?php endif; ?>
                        <?= $block->escapeHtml($docName ?: 'Document #' . ($index + 1)) ?>
                        <?php if ($docId !== ''): ?>
                            <span class="ts-doc-id">ID: <?= $block->escapeHtml($docId) ?></span>
                        <?php endif; ?>
                        <?php if ($docSku !== ''): ?>
                            <span class="ts-doc-id">SKU: <?= $block->escapeHtml($docSku) ?></span>
                        <?php endif; ?>
                    </div>
                    <div class="ts-doc-fields">
                        <?php foreach ($previewFields as $fieldName): ?>
                            <?php if (!isset($doc[$fieldName]) || $fieldName === 'name' || $fieldName === 'id' || $fieldName === 'sku') { continue; } ?>
                            <?php
                            $val = $doc[$fieldName];
                            if (is_array($val)) { $val = implode(', ', $val); }
                            if (is_bool($val)) { $val = $val ? 'true' : 'false'; }
                            $val = (string) $val;
                            if ($val === '') { continue; }
                            ?>
                            <div class="ts-doc-field">
                                <div class="ts-doc-label"><?= $block->escapeHtml($fieldName) ?></div>
                                <div class="ts-doc-val"><?= $block->escapeHtml(mb_substr($val, 0, 80)) ?><?= mb_strlen($val) > 80 ? '…' : '' ?></div>
                            </div>
                        <?php endforeach; ?>
                    </div>
                    <button type="button" class="ts-doc-toggle" onclick="var r=this.nextElementSibling;if(r.style.display==='none'){r.style.display='block';this.textContent='Hide JSON';}else{r.style.display='none';this.textContent='Show JSON';}">Show JSON</button>
                    <div class="ts-doc-raw" style="display:none;"><?= $block->escapeHtml(json_encode($doc, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES)) ?></div>
                </div>
            <?php endforeach; ?>
        <?php endif; ?>
    </div>
</div>
