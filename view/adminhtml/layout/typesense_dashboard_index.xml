<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <title>TypeSense Dashboard</title>
    </head>
    <body>
        <referenceContainer name="content">
            <block class="Magento\Framework\View\Element\Template"
                   name="typesense.dashboard"
                   template="RunAsRoot_TypeSense::dashboard/index.phtml">
                <arguments>
                    <argument name="view_model" xsi:type="object">RunAsRoot\TypeSense\ViewModel\Adminhtml\DashboardViewModel</argument>
                </arguments>
            </block>
        </referenceContainer>
    </body>
</page>
