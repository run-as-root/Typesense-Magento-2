/** @var Escaper $escaper */
/** @var Template $block */
/** @var ViewModelRegistry $viewModels */

/** @var LandingPageViewModel $viewModel */
$viewModel = $block->getData('view_model');
$landingPage = $viewModel->getLandingPage();
if (!$landingPage) {
    return;
}

/** @var HyvaCsp $hyvaCsp */
$hyvaCsp = $viewModels->require(HyvaCsp::class);

$config = $viewModel->getJsonSearchConfig();
$cmsContent = $viewModel->getCmsContent();
$bannerConfig = $viewModel->getBannerConfig();
?>

<script src="https://cdn.jsdelivr.net/npm/typesense@1.8.2/dist/typesense.min.js"></script>

