                <option value="price:asc"><?= $escaper->escapeHtml(__('Price: Low to High')) ?></option>
                <option value="price:desc"><?= $escaper->escapeHtml(__('Price: High to Low')) ?></option>
                <option value="created_at:desc"><?= $escaper->escapeHtml(__('Newest')) ?></option>
            </select>
        </div>
    </div>

    <div class="flex gap-6">
