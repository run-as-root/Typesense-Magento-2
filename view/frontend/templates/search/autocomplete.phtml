<?php
/** @var \Magento\Framework\View\Element\Template $block */
/** @var \RunAsRoot\TypeSense\ViewModel\Frontend\AutocompleteConfigViewModel $viewModel */
$viewModel = $block->getData('view_model');
if (!$viewModel->isEnabled()) {
    return;
}
$config = $viewModel->getJsonConfig();
?>

<script src="https://cdn.jsdelivr.net/npm/typesense@1.8.2/dist/typesense.min.js"></script>
<link rel="stylesheet" href="<?= $block->getViewFileUrl('RunAsRoot_TypeSense::css/autocomplete.css') ?>"/>

<div x-data="typesenseAutocomplete(<?= $block->escapeHtmlAttr($config) ?>)"
     x-on:click.away="isOpen = false"
     class="typesense-autocomplete-wrapper relative">

    <input type="text"
           x-model="query"
           x-on:input.debounce.300ms="search()"
           x-on:keydown.escape="isOpen = false"
           x-on:keydown.arrow-down.prevent="moveDown()"
           x-on:keydown.arrow-up.prevent="moveUp()"
           x-on:keydown.enter.prevent="selectCurrent()"
           x-on:focus="query.length >= 2 && (isOpen = true)"
           placeholder="<?= $block->escapeHtmlAttr(__('Search...')) ?>"
           class="form-input w-full"
           autocomplete="off"/>

    <div x-show="isOpen"
         x-cloak
         class="typesense-autocomplete-dropdown absolute z-50 w-full bg-white border border-gray-200 rounded-b shadow-lg mt-1 max-h-96 overflow-y-auto">

        <!-- Suggestions -->
        <template x-if="results.suggestions.length > 0">
            <div class="p-2 border-b">
                <h4 class="text-xs font-bold text-gray-500 uppercase mb-1"><?= $block->escapeHtml(__('Suggestions')) ?></h4>
                <template x-for="(hit, i) in results.suggestions" :key="hit.document.id">
                    <a x-on:click="query = hit.document.q; isOpen = false; search()"
                       class="block px-2 py-1 text-sm hover:bg-gray-100 cursor-pointer"
                       :class="selectedIndex === i ? 'bg-gray-100' : ''"
                       x-text="hit.document.q"></a>
                </template>
            </div>
        </template>

        <!-- Products -->
        <template x-if="results.products.length > 0">
            <div class="p-2 border-b">
                <h4 class="text-xs font-bold text-gray-500 uppercase mb-1"><?= $block->escapeHtml(__('Products')) ?></h4>
                <template x-for="(hit, i) in results.products" :key="hit.document.id">
                    <a :href="'/' + hit.document.url"
                       class="flex items-center gap-3 px-2 py-2 hover:bg-gray-100 rounded"
                       :class="selectedIndex === (results.suggestions.length + i) ? 'bg-gray-100' : ''">
                        <img :src="hit.document.image_url"
                             :alt="hit.document.name"
                             class="w-10 h-10 object-contain"
                             loading="lazy"
                             x-show="hit.document.image_url"/>
                        <div class="flex-1 min-w-0">
                            <p class="text-sm font-medium truncate" x-text="hit.document.name"></p>
                            <p class="text-sm text-gray-600" x-text="hit.document.price ? '$' + hit.document.price : ''"></p>
                        </div>
                    </a>
                </template>
            </div>
        </template>

        <!-- Categories -->
        <template x-if="results.categories.length > 0">
            <div class="p-2">
                <h4 class="text-xs font-bold text-gray-500 uppercase mb-1"><?= $block->escapeHtml(__('Categories')) ?></h4>
                <template x-for="(hit, i) in results.categories" :key="hit.document.id">
                    <a :href="'/' + hit.document.url"
                       class="block px-2 py-1 text-sm hover:bg-gray-100"
                       :class="selectedIndex === (results.suggestions.length + results.products.length + i) ? 'bg-gray-100' : ''"
                       x-text="hit.document.name"></a>
                </template>
            </div>
        </template>

        <!-- No results -->
        <template x-if="hasSearched && results.products.length === 0 && results.categories.length === 0 && results.suggestions.length === 0">
            <div class="p-4 text-center text-sm text-gray-500">
                <?= $block->escapeHtml(__('No results found')) ?>
            </div>
        </template>
    </div>
</div>

<script src="<?= $block->getViewFileUrl('RunAsRoot_TypeSense::js/autocomplete.js') ?>"></script>
