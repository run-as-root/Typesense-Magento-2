<?php
/**
 * Typesense Instant Search Results — Hyva CSP-compatible
 *
 * Uses JS DOM rendering for product grid, facets, and pagination
 * to avoid CSP-blocked Alpine expressions.
 */

declare(strict_types=1);

use Hyva\Theme\Model\ViewModelRegistry;
use Hyva\Theme\ViewModel\HyvaCsp;
use Magento\Framework\Escaper;
use Magento\Framework\View\Element\Template;
use RunAsRoot\TypeSense\ViewModel\Frontend\InstantSearchConfigViewModel;

/** @var Escaper $escaper */
/** @var Template $block */
/** @var ViewModelRegistry $viewModels */

/** @var InstantSearchConfigViewModel $viewModel */
$viewModel = $block->getData('view_model');
if (!$viewModel->isEnabled()) {
    return;
}

/** @var HyvaCsp $hyvaCsp */
$hyvaCsp = $viewModels->require(HyvaCsp::class);

$config = $viewModel->getJsonConfig();
$sortOptions = $viewModel->getSortOptions();
?>

<script src="https://cdn.jsdelivr.net/npm/typesense@1.8.2/dist/typesense.min.js"></script>
<script>
    function initTypesenseInstantSearch() {
        const config = <?= /* @noEscape */ $config ?>;

        return {
            query: new URLSearchParams(window.location.search).get('q') || '',
            hits: [],
            facets: [],
            stats: '',
            page: 1,
            totalPages: 1,
            sortBy: '',
            filters: {},
            client: null,

            init() {
                this.client = new Typesense.Client({
                    nodes: [{ host: config.typesenseHost, port: String(config.typesensePort), protocol: config.typesenseProtocol }],
                    apiKey: config.typesenseSearchOnlyApiKey,
                    connectionTimeoutSeconds: 2,
                });

                // Bind sort change via native event (CSP blocks @change)
                const sortSelect = this.$el.querySelector('[data-sort-select]');
                if (sortSelect) {
                    sortSelect.addEventListener('change', () => {
                        this.sortBy = sortSelect.value;
                        this.page = 1;
                        this.search();
                    });
                }

                if (this.query) this.search();
            },

            async search() {
                const perPage = config.productsPerPage || 24;
                const searchParams = {
                    q: this.query || '*',
                    query_by: 'name,sku,description',
                    per_page: perPage,
                    page: this.page,
                    facet_by: config.facetAttributes.join(','),
                    max_facet_values: 20,
                };
                if (this.sortBy) searchParams.sort_by = this.sortBy;

                const filterParts = [];
                for (const [field, values] of Object.entries(this.filters)) {
                    if (values.length > 0) filterParts.push(field + ':[' + values.join(',') + ']');
                }
                if (filterParts.length > 0) searchParams.filter_by = filterParts.join(' && ');

                try {
                    const result = await this.client.collections(config.productCollection).documents().search(searchParams);
                    this.hits = result.hits || [];
                    this.facets = result.facet_counts || [];
                    this.totalPages = Math.ceil((result.found || 0) / perPage);
                    this.stats = (result.found || 0) + ' results found in ' + result.search_time_ms + 'ms';
                } catch (error) {
                    console.error('Typesense instant search error:', error);
                }

                this.renderProducts();
                this.renderFacets();
                this.renderPagination();
            },

            toggleFilter(field, value) {
                if (!this.filters[field]) this.filters[field] = [];
                const idx = this.filters[field].indexOf(value);
                if (idx === -1) { this.filters[field] = [...this.filters[field], value]; }
                else { this.filters[field] = this.filters[field].filter(v => v !== value); }
                this.page = 1;
                this.search();
            },

            isFilterActive(field, value) {
                return this.filters[field] ? this.filters[field].includes(value) : false;
            },

            nextPage() { if (this.page < this.totalPages) { this.page++; this.search(); window.scrollTo(0, 0); } },
            prevPage() { if (this.page > 1) { this.page--; this.search(); window.scrollTo(0, 0); } },

            onSortChange() {
                this.page = 1;
                this.search();
            },

            esc(str) {
                const div = document.createElement('div');
                div.textContent = String(str || '');
                return div.innerHTML;
            },

            renderProducts() {
                const container = this.$el.querySelector('[data-products]');
                if (!container) return;

                if (this.hits.length === 0 && this.stats !== '') {
                    container.innerHTML = '<div class="text-center py-16 col-span-full">'
                        + '<p class="text-gray-500 text-lg"><?= $escaper->escapeJs(__('No products found')) ?></p>'
                        + '<p class="text-gray-400 text-sm mt-2"><?= $escaper->escapeJs(__('Try adjusting your search or filters')) ?></p>'
                        + '</div>';
                    return;
                }

                if (this.hits.length === 0) {
                    container.innerHTML = '<div class="text-center py-16 col-span-full"><p class="text-gray-400 text-sm"><?= $escaper->escapeJs(__('Enter a search term to see results')) ?></p></div>';
                    return;
                }

                let html = '';
                for (const hit of this.hits) {
                    const doc = hit.document;
                    const price = doc.price ? '$' + Number(doc.price).toFixed(2) : '';
                    const imgHtml = doc.image_url
                        ? '<img src="' + this.esc(doc.image_url) + '" alt="' + this.esc(doc.name) + '" class="w-full h-full object-contain" loading="lazy"/>'
                        : '<div class="w-full h-full bg-gray-100 flex items-center justify-center"><span class="text-gray-300 text-xs">No image</span></div>';

                    let tileAttrsHtml = '';
                    if (config.tileAttributes && config.tileAttributes.length > 0) {
                        for (const attr of config.tileAttributes) {
                            const val = doc[attr];
                            if (val !== undefined && val !== null && val !== '') {
                                const displayVal = Array.isArray(val) ? val.join(', ') : String(val);
                                tileAttrsHtml += '<div class="text-xs text-gray-500 truncate"><span class="text-gray-400">' + this.esc(attr.replace(/_/g, ' ')) + ':</span> ' + this.esc(displayVal) + '</div>';
                            }
                        }
                    }

                    html += '<div class="border border-gray-200 rounded-lg p-3 flex flex-col hover:shadow-md transition-shadow">'
                        + '<a href="/' + this.esc(doc.url) + '" class="flex flex-col flex-1">'
                        + '<div class="aspect-square mb-3 overflow-hidden rounded">' + imgHtml + '</div>'
                        + '<h3 class="text-sm font-medium text-gray-800 mb-1 line-clamp-2">' + this.esc(doc.name) + '</h3>'
                        + tileAttrsHtml
                        + '<div class="mt-auto pt-2"><span class="text-sm font-bold text-gray-800">' + this.esc(price) + '</span></div>'
                        + '</a>'
                        + '<a href="/' + this.esc(doc.url) + '" class="mt-3 w-full text-center text-xs font-medium text-white bg-blue-600 hover:bg-blue-700 rounded px-3 py-2 transition-colors">'
                        + '<?= $escaper->escapeJs(__('View Product')) ?>'
                        + '</a></div>';
                }

                container.innerHTML = html;
            },

            renderFacets() {
                const container = this.$el.querySelector('[data-facets]');
                if (!container) return;

                if (this.facets.length === 0) {
                    container.innerHTML = '';
                    return;
                }

                let html = '';
                for (const facet of this.facets) {
                    const label = facet.field_name.replace(/_/g, ' ');
                    html += '<div class="mb-6 border-b pb-4">'
                        + '<h3 class="font-semibold text-gray-800 mb-3 capitalize">' + this.esc(label) + '</h3>';

                    for (const count of facet.counts) {
                        const isActive = this.isFilterActive(facet.field_name, count.value);
                        html += '<label class="flex items-center gap-2 text-sm text-gray-700 mb-1.5 cursor-pointer hover:text-gray-900">'
                            + '<input type="checkbox" ' + (isActive ? 'checked' : '') + ' data-facet-field="' + this.esc(facet.field_name) + '" data-facet-value="' + this.esc(count.value) + '" class="rounded border-gray-300 text-blue-600 focus:ring-blue-500 ts-facet-checkbox"/>'
                            + '<span class="flex-1">' + this.esc(count.value) + '</span>'
                            + '<span class="text-gray-400 text-xs">(' + count.count + ')</span>'
                            + '</label>';
                    }
                    html += '</div>';
                }

                container.innerHTML = html;

                container.querySelectorAll('.ts-facet-checkbox').forEach(cb => {
                    cb.addEventListener('change', () => {
                        this.toggleFilter(cb.dataset.facetField, cb.dataset.facetValue);
                    });
                });
            },

            renderPagination() {
                const container = this.$el.querySelector('[data-pagination]');
                if (!container) return;

                if (this.totalPages <= 1) {
                    container.innerHTML = '';
                    return;
                }

                const prevDisabled = this.page <= 1;
                const nextDisabled = this.page >= this.totalPages;

                container.innerHTML = '<div class="flex justify-center items-center gap-3 mt-8">'
                    + '<button class="px-4 py-2 text-sm border border-gray-300 rounded transition-colors ' + (prevDisabled ? 'opacity-40 cursor-not-allowed' : 'hover:bg-gray-100 cursor-pointer') + '" data-action="prev" ' + (prevDisabled ? 'disabled' : '') + '><?= $escaper->escapeJs(__('Previous')) ?></button>'
                    + '<span class="text-sm text-gray-600">' + this.page + ' / ' + this.totalPages + '</span>'
                    + '<button class="px-4 py-2 text-sm border border-gray-300 rounded transition-colors ' + (nextDisabled ? 'opacity-40 cursor-not-allowed' : 'hover:bg-gray-100 cursor-pointer') + '" data-action="next" ' + (nextDisabled ? 'disabled' : '') + '><?= $escaper->escapeJs(__('Next')) ?></button>'
                    + '</div>';

                const prevBtn = container.querySelector('[data-action="prev"]');
                const nextBtn = container.querySelector('[data-action="next"]');
                if (prevBtn) prevBtn.addEventListener('click', () => this.prevPage());
                if (nextBtn) nextBtn.addEventListener('click', () => this.nextPage());
            },
        };
    }

    window.addEventListener('alpine:init', () => {
        Alpine.data('initTypesenseInstantSearch', initTypesenseInstantSearch);
    }, { once: true });
</script>
<?php $hyvaCsp->registerInlineScript() ?>

<div x-data="initTypesenseInstantSearch"
     class="typesense-instant-search container mx-auto px-4 py-6">

    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-3">
        <p class="text-sm text-gray-600" x-text="stats"></p>
        <div class="flex items-center gap-2">
            <label for="typesense-sort" class="text-sm text-gray-600 shrink-0"><?= $escaper->escapeHtml(__('Sort by:')) ?></label>
            <select id="typesense-sort" data-sort-select
                    class="text-sm border border-gray-300 rounded px-3 py-1.5 bg-white focus:outline-none focus:ring-2 focus:ring-blue-500">
                <?php foreach ($sortOptions as $option): ?>
                    <option value="<?= $escaper->escapeHtmlAttr($option['value']) ?>"><?= $escaper->escapeHtml(__($option['label'])) ?></option>
                <?php endforeach; ?>
            </select>
        </div>
    </div>

    <div class="flex gap-6">
        <aside class="w-64 shrink-0 hidden lg:block" data-facets></aside>

        <div class="flex-1 min-w-0">
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4" data-products>
                <div class="text-center py-16 col-span-full">
                    <p class="text-gray-400 text-sm"><?= $escaper->escapeHtml(__('Loading results…')) ?></p>
                </div>
            </div>

            <div data-pagination></div>
        </div>
    </div>
</div>
