<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceBlock name="header.search">
            <block class="Magento\Framework\View\Element\Template"
                   name="typesense.autocomplete"
                   template="RunAsRoot_TypeSense::search/autocomplete.phtml"
                   after="-">
                <arguments>
                    <argument name="view_model" xsi:type="object">RunAsRoot\TypeSense\ViewModel\Frontend\AutocompleteConfigViewModel</argument>
                </arguments>
            </block>
        </referenceBlock>
    </body>
</page>
