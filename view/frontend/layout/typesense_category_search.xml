<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <css src="RunAsRoot_TypeSense::css/instant-search.css"/>
    </head>
    <body>
        <referenceContainer name="content">
            <block class="Magento\Framework\View\Element\Template"
                   name="typesense.category.search"
                   template="RunAsRoot_TypeSense::category/typesense-listing.phtml"
                   before="-">
                <arguments>
                    <argument name="view_model" xsi:type="object">RunAsRoot\TypeSense\ViewModel\Frontend\CategorySearchConfigViewModel</argument>
                </arguments>
            </block>
        </referenceContainer>
        <!-- Remove default product listing to avoid duplicate content -->
        <referenceBlock name="category.products.list" remove="true"/>
    </body>
</page>
