parameters:
    level: 6
    paths:
        - .
    excludePaths:
        - Test/*
        - vendor/*
        - view/*
    ignoreErrors:
        - '#Class Magento\\#'
        - '#Class Typesense\\#'
        - '#Class Psr\\#'
        - '#no value type specified in iterable type array#'
        - '#Call to an undefined method Magento\\Framework\\#'
        - '#is never read, only written#'
        - '#Magento\\Framework\\Phrase given#'
